# ─────────────────────────────────────────────────────────────────────────────
# Copy this file to `.env` and fill in real values. NEVER commit `.env`.
# Placeholders only — do not put real credentials in this example file.
# ─────────────────────────────────────────────────────────────────────────────

# ── PostgreSQL connection (read-only access strongly preferred) ──────────────
DB_HOST=your-db-host
DB_PORT=5432
DB_NAME=your-database-name
DB_USER=your-readonly-username
DB_PASSWORD=your-password
# PostgreSQL sslmode: disable | allow | prefer | require | verify-ca | verify-full
DB_SSL_MODE=prefer

# Connection / statement timeouts in seconds (defence against runaway queries).
DB_CONNECT_TIMEOUT=10
DB_STATEMENT_TIMEOUT=30

# ── Optional domain scoping (used by later phases, optional now) ─────────────
DEFAULT_FACILITY_ID=
DEFAULT_PROJECT_ID=

# ── LLM configuration (Groq, native tool calling) ────────────────────────────
LLM_PROVIDER=groq
# Groq API key (free tier). Get one at https://console.groq.com
GROQ_API_KEY=your-groq-api-key
# The two models compared for H3/H4 (A = larger, B = smaller).
# A note on the 70B: llama-3.3-70b-versatile exceeds the Groq free daily token
# cap for a full run, so the evaluation used qwen/qwen3-32b as model A.
MODEL_A=qwen/qwen3-32b
MODEL_B=llama-3.1-8b-instant
# (Decoding temperature is hard-coded to 0.0 in code for reproducibility.)
